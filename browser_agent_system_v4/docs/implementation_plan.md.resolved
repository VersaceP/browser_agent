│   ├── browser_tools.py            # Playwright CDP 浏览器工具
│   ├── file_tools.py               # 文件读写工具
│   └── code_tools.py               # Python 沙箱代码工具
├── worktrees/                      # 运行时隔离目录
└── docs/
    ├── architecture_v4.md
    └── implementation_plan_v4_merged.md
